#!/usr/bin/env sh
set -eu

# Try active conda env, then project conda env datathon, then PATH
if [ -n "${CONDA_PREFIX:-}" ] && [ -x "$CONDA_PREFIX/bin/python" ]; then
    PYTHON="$CONDA_PREFIX/bin/python"
else
    for dir in /opt/anaconda3 /opt/homebrew/anaconda3 ~/anaconda3 ~/miniconda3 ~/miniforge3; do
        [ -x "$dir/envs/datathon/bin/python" ] && { PYTHON="$dir/envs/datathon/bin/python"; break; }
    done
fi
PYTHON="${PYTHON:-$(command -v python3 || command -v python)}"

BRANCH="$(git rev-parse --abbrev-ref HEAD)"
REGEX='^(((feature|fix|eng|chore|bugfix|hotfix)/[A-Za-z0-9._-]+)|dev|main)$'

if ! printf '%s' "$BRANCH" | grep -Eq "$REGEX"; then
  echo "Commit rejected: branch '$BRANCH' does not match '$REGEX'" >&2
  exit 1
fi

STAGED_PY_FILES="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.py$' || true)"

if [ -n "$STAGED_PY_FILES" ]; then
  echo "Running Python syntax checks on staged files..."
  printf '%s\n' "$STAGED_PY_FILES" | while IFS= read -r file; do
    [ -f "$file" ] && $PYTHON -m py_compile "$file"
  done
fi

echo "Running unit tests..."
$PYTHON -m pytest -q tests/unit
