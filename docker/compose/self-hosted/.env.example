# ─────────────────────────────────────────────────────────────────────────────
# Pulse Self-Hosted — Docker Compose Environment
#
# Copy to .env and fill in all REQUIRED (★) values before running:
#   cp .env.example .env
#   docker compose pull
#   docker compose up -d
#
# Full guide: README.md in this folder (docker/compose/self-hosted/)
#
# Compose sets DATABASE_URL, QDRANT_URL, REDIS_URL, and deployment mode for you.
# License server URL and JWT verification public key are baked into pulseai/pulse at
# image build time (see docker/images/pulse/Dockerfile) — not set in this file.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# HOST  ★
# ══════════════════════════════════════════════════════════════════════════════

# Public HTTP port (maps to nginx inside the pulse container)
PORT=80

# Image tag when pulling from Docker Hub
# ENTIVIA_VERSION=latest


# ══════════════════════════════════════════════════════════════════════════════
# DATABASE  ★ REQUIRED
# ══════════════════════════════════════════════════════════════════════════════

POSTGRES_PASSWORD=

# Do not set DATABASE_URL — compose wires pulse → db automatically.


# ══════════════════════════════════════════════════════════════════════════════
# SECURITY  ★ REQUIRED
# ══════════════════════════════════════════════════════════════════════════════

# Generate: openssl rand -hex 32
JWT_SECRET=

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=15
PASSWORD_MIN_LENGTH=8


# ══════════════════════════════════════════════════════════════════════════════
# PIPELINE LLM PROVIDERS  ★ REQUIRED (at least one)
# ══════════════════════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=
GROQ_API_KEY=


# ══════════════════════════════════════════════════════════════════════════════
# LICENSE (Pro)
# ══════════════════════════════════════════════════════════════════════════════

# After install: sign in → Settings → License → paste your key (plc_… from purchase email).
# No license variables belong in this file for standard Docker Hub installs.


# ══════════════════════════════════════════════════════════════════════════════
# EMBEDDINGS + VECTOR SEARCH
# ══════════════════════════════════════════════════════════════════════════════

# Required for semantic entity search and RAG. QDRANT_URL is set by compose.
VOYAGEAI_API_KEY=

# QDRANT_URL=http://qdrant:6333   ← set by compose — do not override unless using external Qdrant


# ══════════════════════════════════════════════════════════════════════════════
# REDIS
# ══════════════════════════════════════════════════════════════════════════════

# Bundled inside the pulse image. Compose sets REDIS_URL — do not override unless debugging.
REDIS_MAX_MEMORY=256mb


# ══════════════════════════════════════════════════════════════════════════════
# EMAIL (optional — needed for verify/reset flows)
# ══════════════════════════════════════════════════════════════════════════════

RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=


# ══════════════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH (optional)
# ══════════════════════════════════════════════════════════════════════════════

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Use your public URL when not on localhost:
# GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/oauth/google/callback


# ══════════════════════════════════════════════════════════════════════════════
# FILE STORAGE (optional — defaults to local volume inside pulse)
# ══════════════════════════════════════════════════════════════════════════════

# STORAGE_BACKEND=local

# ASSETS_S3_BUCKET=
# AWS_REGION=us-east-1


# ══════════════════════════════════════════════════════════════════════════════
# APPLICATION
# ══════════════════════════════════════════════════════════════════════════════

# Public URL users open in the browser. Required for email links (verify, reset,
# accept invite) and CORS. Set to your domain if behind a reverse proxy.
#   default localhost (compose):  http://localhost
#   custom port:                   http://localhost:3000
#   public hostname:               https://app.example.com
FRONTEND_URL=http://localhost

ENVIRONMENT=production
LOG_LEVEL=INFO
# LOG_FORMAT=json
# File log-stream destinations write under /var/log/pulse/streams (pulse_logs volume in compose)

API_WORKERS=1
AGENT_WORKERS=1
PIPELINE_INTERVAL_HOURS=4
PIPELINE_ORG_DISCOVERY_INTERVAL_MINUTES=15
