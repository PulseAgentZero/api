# Pulse cloud compose — copy to .env and fill in values
# Used by: api, worker, agent, scheduler (env_file) and license service.
# Many URLs (DATABASE_URL, REDIS_URL, QDRANT_URL) are also set in docker-compose.yml.

# ── Postgres (required) ───────────────────────────────────────────────────────
POSTGRES_USER=pulse
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pulse
# POSTGRES_PORT=5432

# ── Auth & secrets (required) ─────────────────────────────────────────────────
JWT_SECRET=
ENCRYPTION_KEY=

# ── LLM (required for pipeline + agent) ───────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Redis (required for worker queue, refresh tokens, rate limits) ────────────
# Compose sets REDIS_URL=redis://redis:6379/0 on app services; keep in sync if you change it.
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
# Local dev:
FRONTEND_URL=http://localhost:3000
# Production (Entivia — CORS + auth email links; use app subdomain):
# FRONTEND_URL=https://app.entivia.online
# Marketing site allowed to call anonymous checkout endpoints:
# MARKETING_URL=https://entivia.online
# Optional comma-separated extra browser origins:
# CORS_ALLOWED_ORIGINS=https://entivia.online,https://app.entivia.online
ENVIRONMENT=development
# ENVIRONMENT=production
DEPLOYMENT_MODE=cloud
LOG_LEVEL=INFO

# ── Vector search (optional; compose wires QDRANT_URL=http://qdrant:6333) ─────
VOYAGEAI_API_KEY=
# QDRANT_API_KEY=          # only if Qdrant requires an API key

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ── Email (renewal reminders, auth, billing) ────────────────────────────────────
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Paystack — cloud subscriptions + optional self-hosted license sales ───────
PAYSTACK_SECRET_KEY=
PAYSTACK_PRO_PLAN_CODE=
PAYSTACK_GROWTH_PLAN_CODE=
PAYSTACK_SELFHOSTED_LICENSE_PRICE=0
BILLING_GRACE_DAYS=7

# Register in Paystack dashboard → Settings → Webhooks:
# https://<your-api-host>/api/v1/billing/webhook

# ── License server (optional — `license` service in compose) ───────────────────
# Cloud API does not require license activation; use when selling self-hosted keys.
LICENSE_SIGNING_PRIVATE_KEY=
LICENSE_SERVER_API_KEY=
PULSE_LICENSE_PUBLIC_KEY=
# LICENSE_SERVER_URL=http://license:8002
# LICENSE_JWT_ISSUER=https://license.pulseai.io

# ── Scheduler (optional — runs in dedicated `scheduler` container only) ───────
# All APScheduler jobs: pipeline cron, studio cache refresh, billing, usage reset.
# STUDIO_REFRESH_SYNC_INTERVAL_MINUTES=5
# PIPELINE_INTERVAL_HOURS=4
# PIPELINE_ORG_DISCOVERY_INTERVAL_MINUTES=15

# ── Compose overrides (optional) ──────────────────────────────────────────────
# API_PORT=8000
# API_WORKERS=2
# AGENT_WORKERS=1
# LICENSE_PORT=8002
# REDIS_MAX_MEMORY=512mb
# QDRANT_HTTP_PORT=6333

# ── File storage (optional — default local volume `uploads_data`) ─────────────
# STORAGE_BACKEND=local          # local | s3 | minio
#
# AWS S3 (STORAGE_BACKEND=s3) — credentials use standard boto3 env vars
# (not listed in app/config/settings.py; read by the AWS SDK at runtime).
# On ECS/EC2 you can omit keys and use an IAM role instead.
# STORAGE_BACKEND=s3
# ASSETS_S3_BUCKET=your-bucket-name
# ASSETS_S3_PREFIX=pulse/assets
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# ASSETS_PUBLIC_BASE_URL=          # optional CDN/CloudFront base URL for public file links
#
# MinIO / S3-compatible (STORAGE_BACKEND=minio) — uses MINIO_* keys, not AWS_*:
# MINIO_ENDPOINT_URL=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=pulse-assets

# ── Production secrets (optional — instead of inline env above) ───────────────
# DATABASE_URL_SECRET_ARN=
# API_SECRETS_ARN=
