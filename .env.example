# Pulse / Entivia (production API)
DATABASE_URL=postgresql+asyncpg://pulse:pulse@localhost:5432/pulse
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=  # Fernet key for client DB credentials

# LLM (required for hackathon agent endpoints)
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Optional cloud embeddings. Hackathon defaults to local fastembed.
VOYAGEAI_API_KEY=

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Hackathon data loader + API
HACKATHON_DATABASE_URL=postgresql+asyncpg://hackathon:hackathon@localhost:5433/hackathon
HACKATHON_ALLOW_SYNTHETIC=1
HACKATHON_EMBEDDING_BACKEND=fastembed
HACKATHON_FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
HACKATHON_USE_PSEUDO_EMBEDDINGS=0
HACKATHON_MAX_YELP_ITEMS=12000
# HACKATHON_YELP_DIR=/path/to/yelp/json/files
