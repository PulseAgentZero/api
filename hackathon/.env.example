# Hackathon API containers
# Copy to hackathon/.env for local/VPS runs:
#   cp hackathon/.env.example hackathon/.env

# LLM (Anthropic required unless you configure another provider in code)
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Local Docker Compose defaults. Usually do not change these when using
# hackathon/docker-compose.yml because services talk over the Compose network.
HACKATHON_DATABASE_URL=postgresql+asyncpg://hackathon:hackathon@postgres:5432/hackathon
QDRANT_URL=http://qdrant:6333

# Embeddings
HACKATHON_EMBEDDING_BACKEND=fastembed
HACKATHON_FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
HACKATHON_USE_PSEUDO_EMBEDDINGS=0

# Loader limits and data sources
HACKATHON_MAX_YELP_ITEMS=12000
HACKATHON_MAX_YELP_USERS=5000
HACKATHON_MIN_REVIEWS=10
HACKATHON_MAX_GOODREADS=1000
HACKATHON_ALLOW_SYNTHETIC=1

# Optional host/container paths. The Makefile normally mounts
# HACKATHON_YELP_HOST_DIR from your host to /data/yelp in the loader container.
HACKATHON_YELP_DIR=/data/yelp
# HACKATHON_GOODREADS_PATH=/data/goodreads/goodreads_books.json.gz

# Public URLs used only to make Swagger/OpenAPI show production endpoints.
# Each service overrides this in hackathon/docker-compose.yml.
# HACKATHON_PUBLIC_API_URL=https://hackathon.entivia.online
