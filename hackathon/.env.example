# This file is only a pointer.
#
# The hackathon Docker Compose file loads the repo-root `.env`:
#   hackathon/docker-compose.yml -> env_file: ../.env
#
# For local or VPS runs, copy the root template instead:
#   cp .env.example .env
#
# Then edit `.env` and set at least:
#   ANTHROPIC_API_KEY=...
#
# Keep hackathon-specific values in the root `.env` too. The root
# `.env.example` contains the supported hackathon variables.
