# Hackathon stack — copy to hackathon/.env and fill in real values.
#   cp hackathon/.env.example hackathon/.env
#
# hackathon/docker-compose.yml loads THIS file (env_file: .env, relative
# to the compose file). The root .env is only used when you run hackathon
# code outside of compose (e.g. `python -m hackathon.eval.run`).

# ── Required: Postgres ────────────────────────────────────────────────────────
# Same value is used by the `postgres` container (POSTGRES_PASSWORD) and by
# the app services (embedded in HACKATHON_DATABASE_URL). Compose will fail
# if this is unset.
HACKATHON_DATABASE_PASSWORD=change-me

# ── Required: LLM provider ────────────────────────────────────────────────────
# Anthropic is the primary; Groq is an optional automatic fallback.
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Optional demo speed mode. Leave unset for the production-like Anthropic default.
# For lower latency in Swagger demos, set Groq as primary and use the instant model.
# HACKATHON_LLM_PROVIDER=groq                 # anthropic | groq
# HACKATHON_LLM_MODEL=llama-3.1-8b-instant    # fastest Groq demo model

# ── Required: Embeddings (Voyage AI) ──────────────────────────────────────────
# Same provider/model the Entivia production stack uses.
VOYAGEAI_API_KEY=

# ── Optional: overrides for the defaults baked into docker-compose.yml ────────
# Uncomment to change. Compose already sets sensible defaults via x-hackathon-env.
# HACKATHON_EMBEDDING_BACKEND=voyage          # voyage | fastembed | pseudo
# HACKATHON_VOYAGE_MODEL=voyage-4-large
# HACKATHON_VECTOR_SIZE=1024
# HACKATHON_FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
# HACKATHON_USE_PSEUDO_EMBEDDINGS=0
# HACKATHON_MAX_YELP_ITEMS=12000
# HACKATHON_MAX_YELP_USERS=5000
# HACKATHON_MIN_REVIEWS=10
# HACKATHON_MAX_GOODREADS=1000
# HACKATHON_ALLOW_SYNTHETIC=1

# ── Optional: Swagger docs ────────────────────────────────────────────────────
# Each service in docker-compose.yml already overrides this per task
# (hackathon-a/-b/.entivia.online). Only set here for non-default deployments.
# HACKATHON_PUBLIC_API_URL=https://hackathon.entivia.online
